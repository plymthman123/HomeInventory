{
  "expo": {
    "name": "HomeInventory",
    "slug": "home-inventory",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "homeinventory",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourdomain.homeinventory",
      "infoPlist": {
        "NSCameraUsageDescription": "HomeInventory uses your camera to photograph items and scan barcodes.",
        "NSPhotoLibraryUsageDescription": "HomeInventory accesses your photos to attach images to items.",
        "NSPhotoLibraryAddUsageDescription": "HomeInventory saves photos to your library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.yourdomain.homeinventory",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow HomeInventory to access your camera to photograph items and scan barcodes."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow HomeInventory to access your photos to attach to items."
        }
      ],
      [
        "expo-secure-store"
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
